<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.cpw.browser.WebBrowser</id>

    <!-- Public plugin name should be written in Title Case. -->
    <name>WebBrowser</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.yourcompany.com">YourCompany</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager. -->
    <description><![CDATA[
        A Simple Browser for IntelliJ IDEA, inspired by VS Code Simple Browser.
        Embed web pages directly in the IDE with navigation, bookmarks, and DevTools support.
    ]]></description>

    <!-- Product and plugin compatibility requirements. -->
    <idea-version since-build="261" until-build="*"/>
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin. -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="WebBrowser"
            factoryClass="com.cpw.browser.BrowserToolWindowFactory"
            icon="/icons/toolwindow.svg"
            anchor="left"
            secondary="false"/>

        <applicationService
            serviceImplementation="com.cpw.browser.bookmark.BookmarkPersistentState"/>

        <applicationService
            serviceImplementation="com.cpw.browser.settings.BrowserSettingsState"/>

        <applicationService
            serviceImplementation="com.cpw.browser.history.BrowsingHistoryState"/>

        <applicationConfigurable
            instance="com.cpw.browser.settings.BrowserSettingsPage"
            displayName="WebBrowser"
            id="com.cpw.browser.settings.BrowserSettingsPage"/>
    </extensions>
    <!-- ж–°еўһпјҡе·Ҙе…·ж ҸActionй…ҚзҪ®пјҲзӣҙжҺҘж·»еҠ еңЁextensionsеҗҺйқўеҚіеҸҜпјү -->
    <actions>
        <!-- жіЁеҶҢжү“ејҖ/е…ій—ӯжөҸи§ҲеҷЁе·Ҙе…·зӘ—еҸЈзҡ„Action -->
        <action
            id="com.cpw.browser.ToggleBrowserAction"
            class="com.cpw.browser.ToggleBrowserAction"
            text="Toggle Web Browser"
            description="Open or close the web browser tool window"
            icon="/icons/toolwindow.svg"> <!-- еӨҚз”ЁдҪ е·Іжңүзҡ„е·Ҙе…·зӘ—еҸЈеӣҫж Ү -->

            <!-- ж–°зүҲUIпјҲ2020.3+пјүпјҡж·»еҠ еҲ°дё»е·Ҙе…·ж ҸжңҖе·Ұдҫ§ -->
            <add-to-group group-id="MainToolbarLeft" anchor="first" />
        </action>
    </actions>
</idea-plugin>
