<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.cpw.browser.WebBrowser</id>

    <!-- Public plugin name should be written in Title Case. -->
    <name>WebBrowser</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>Pengwei Chen</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager. -->
    <description><![CDATA[
        A fully-featured embedded web browser plugin for JetBrains IDEs.  <br>
        一款功能完整类似Chrome的浏览器插件.<br>
        <b>Features / 功能特性：</b><br>
        <ul>
            <li><b>Any URL</b> — Enter any URL to browse directly.<br>
            <b>任意网址</b> — 输入任意网址即可直接浏览。</li>
            <li><b>Search Engine</b> — Search directly when input is not a URL.<br>
            <b>搜索引擎</b> — 输入内容非网址时，可直接使用搜索引擎。</li>
            <li><b>Dual Display</b> — Sidebar tool window or editor tab.<br>
            <b>支持侧边栏工具窗口和编辑区标签页两种模式</b> </li>
            <li><b>Multi-Tab</b> — Create, close, and switch between tabs.<br>
            <b>多标签页</b> </li>
            <li><b>Bookmarks</b> — Manage bookmarks.<br>
            <b>书签管理</b> </li>
            <li><b>History</b> — Browsing history records.<br>
            <b>浏览历史</b> </li>
            <li><b>DevTools</b> — Embedded split-pane or separate window mode.<br>
            <b>开发者工具</b> — 支持嵌入分屏或独立窗口模式。</li>
            <li><b>Zoom Controls</b> — Zoom in/out/reset.<br>
            <b>缩放控制</b> — 放大/缩小/重置。</li>
            <li><b>Auto-Refresh</b> — Auto-reload pages at configurable intervals.<br>
            <b>自动刷新</b> — 按可配置间隔自动重新加载页面。</li>
            <li><b>Internationalization</b> — Supports 7 languages with instant switching.<br>
            <b>国际化</b> — 支持 7 种语言（英文、简体中文、日文、韩文、法文、德文），即时切换。</li>
            <li><b>More</b> — Other customizable settings.<br>
            <b>其他更多功能</b> </li>
        </ul>
        <br>
        GitHub: <a href="https://github.com/hccpw007/JetBrains-WebBrowser-plugin">https://github.com/hccpw007/JetBrains-WebBrowser-plugin</a>
    ]]></description>

    <!-- Product and plugin compatibility requirements. -->
    <idea-version since-build="253" until-build="*"/>
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin. -->
    <extensions defaultExtensionNs="com.intellij">
        <jcef.appRequiredArgumentsProvider implementation="com.cpw.browser.JcefArgsProvider"/>
        <toolWindow
            id="WebBrowser"
            factoryClass="com.cpw.browser.toolwindow.BrowserToolWindowFactory"
            icon="/icons/toolwindow.svg"
            anchor="left"
            secondary="false"/>

        <applicationService
            serviceImplementation="com.cpw.browser.bookmark.BookmarkPersistentState"/>

        <applicationService
            serviceImplementation="com.cpw.browser.settings.BrowserSettingsState"/>

        <applicationService
            serviceImplementation="com.cpw.browser.history.BrowsingHistoryState"/>

        <projectService
            serviceImplementation="com.cpw.browser.BrowserProjectService"/>

        <applicationConfigurable
            instance="com.cpw.browser.settings.BrowserSettingsPage"
            displayName="WebBrowser"
            id="com.cpw.browser.settings.BrowserSettingsPage"/>

        <fileEditorProvider
            implementation="com.cpw.browser.editor.BrowserFileEditorProvider"/>

        <fileType
            name="WebBrowser"
            implementationClass="com.cpw.browser.editor.BrowserFileType"
            fieldName="INSTANCE"
            extensions="webbrowser"/>

        <editorTabTitleProvider
            implementation="com.cpw.browser.editor.BrowserEditorTabTitleProvider"/>

    </extensions>
    <!-- 新增：工具栏Action配置（直接添加在extensions后面即可） -->
    <actions>
        <!-- 注册打开/关闭浏览器工具窗口的Action -->
        <action
            id="com.cpw.browser.ToggleBrowserAction"
            class="com.cpw.browser.action.ToggleBrowserAction"
            text="WebBrowser"
            description="Open or close the web browser tool window"
            icon="/icons/toolwindow.svg">
            <add-to-group group-id="MainToolbarRight" anchor="first" />
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut first-keystroke="alt shift W" keymap="$default"/>
        </action>
    </actions>
</idea-plugin>
